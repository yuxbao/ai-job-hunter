# === LLM 配置 ===
# 支持任何 OpenAI 兼容 API (DeepSeek / 通义千问 / Moonshot 等)
LLM_API_KEY=sk-xxx
LLM_MODEL=gpt-4o-mini
# LLM_BASE_URL=https://api.deepseek.com/v1

# === 搜索 API ===
# Tavily (推荐, https://tavily.com 注册免费获取)
TAVILY_API_KEY=tvly-xxx

# === Agent 配置 ===
TARGET_JOB_COUNT=50
MAX_ITERATIONS=5
MOCK_MODE=false
